{
  "manifest_version": 3,
  "name": "Reachard",
  "description": "Find company contacts from job pages, company sites, and LinkedIn profiles.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://www.linkedin.com/*",
    "https://reachard.co/*",
    "https://www.reachard.co/*",
    "https://contacts.reachard.co/*",
    "https://reachard.studio/*",
    "https://www.reachard.studio/*",
    "https://contacts.reachard.studio/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://reachard.studio/*",
        "https://www.reachard.studio/*",
        "https://reachard.co/*",
        "https://www.reachard.co/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["web_bridge.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html",
  "externally_connectable": {
    "matches": [
      "https://reachard.co/*",
      "https://www.reachard.co/*",
      "https://contacts.reachard.co/*",
      "https://reachard.studio/*",
      "https://www.reachard.studio/*",
      "https://contacts.reachard.studio/*",
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*"
    ]
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
